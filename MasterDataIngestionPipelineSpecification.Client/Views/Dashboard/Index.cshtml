@using MasterDataIngestionPipelineSpecification.Api.Dtos
@model DashboardSummaryDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Pipeline Dashboard</h4>
        <small class="text-muted">Real-time overview of ingestion and processing health</small>
    </div>
    <button class="btn btn-outline-primary btn-sm" onclick="location.reload()">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </button>
</div>

<!-- KPI Cards Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-muted small">Total Requests</div>
                        <div class="fs-3 fw-bold text-dark">@Model.TotalRequests</div>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-arrow-down-circle text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-muted small">Customer Requests</div>
                        <div class="fs-3 fw-bold text-primary">@Model.CustomerMetrics.TotalRequests</div>
                        <div class="small text-success">@Model.CustomerMetrics.ApiSuccessRate% API Success</div>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-person-fill text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-muted small">Item Requests</div>
                        <div class="fs-3 fw-bold text-success">@Model.ItemMetrics.TotalRequests</div>
                        <div class="small text-success">@Model.ItemMetrics.ApiSuccessRate% API Success</div>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-box-fill text-success fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-muted small">Processing Errors</div>
                        <div class="fs-3 fw-bold @(Model.ProcessingMatrix.Error > 0 ? "text-danger" : "text-secondary")">
                            @Model.ProcessingMatrix.Error
                        </div>
                        <div class="small text-muted">@Model.ProcessingMatrix.Pending Pending</div>
                    </div>
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <!-- Domain Breakdown Table -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 fw-semibold pt-3">
                <i class="bi bi-bar-chart-line me-2 text-primary"></i>Domain Breakdown
            </div>
            <div class="card-body">
                <table class="table table-sm table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Domain</th>
                            <th class="text-end">Requests</th>
                            <th class="text-end">API %</th>
                            <th class="text-end">Proc %</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-primary">Customer</span></td>
                            <td class="text-end fw-semibold">@Model.CustomerMetrics.TotalRequests</td>
                            <td class="text-end text-success">@Model.CustomerMetrics.ApiSuccessRate%</td>
                            <td class="text-end text-info">@Model.CustomerMetrics.ProcessingSuccessRate%</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-success">Item</span></td>
                            <td class="text-end fw-semibold">@Model.ItemMetrics.TotalRequests</td>
                            <td class="text-end text-success">@Model.ItemMetrics.ApiSuccessRate%</td>
                            <td class="text-end text-info">@Model.ItemMetrics.ProcessingSuccessRate%</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Ingestion Status Doughnut -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 fw-semibold pt-3">
                <i class="bi bi-pie-chart me-2 text-success"></i>API Ingestion Status
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <div style="max-height:200px; max-width:220px;">
                    <canvas id="ingestionChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Processing Status Doughnut -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 fw-semibold pt-3">
                <i class="bi bi-gear me-2 text-warning"></i>Processing Status
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <div style="max-height:200px; max-width:220px;">
                    <canvas id="processingChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Processing Status Bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 fw-semibold pt-3">
        <i class="bi bi-activity me-2 text-info"></i>Processing Pipeline Status
    </div>
    <div class="card-body">
        @{
            int totalSuccessful = Model.ProcessingMatrix.Pending + Model.ProcessingMatrix.Processed + Model.ProcessingMatrix.Error;
            double processedPct = totalSuccessful > 0 ? (double)Model.ProcessingMatrix.Processed / totalSuccessful * 100 : 0;
            double pendingPct = totalSuccessful > 0 ? (double)Model.ProcessingMatrix.Pending / totalSuccessful * 100 : 0;
            double errorPct = totalSuccessful > 0 ? (double)Model.ProcessingMatrix.Error / totalSuccessful * 100 : 0;
        }
        <div class="progress" style="height: 28px; border-radius: 8px;">
            <div class="progress-bar bg-success" style="width:@processedPct.ToString("0.0")%" title="Processed">
                @if (processedPct > 5)
                {
                    <span>@Model.ProcessingMatrix.Processed Processed</span>
                }
            </div>
            <div class="progress-bar bg-warning text-dark" style="width:@pendingPct.ToString("0.0")%" title="Pending">
                @if (pendingPct > 5)
                {
                    <span>@Model.ProcessingMatrix.Pending Pending</span>
                }
            </div>
            <div class="progress-bar bg-danger" style="width:@errorPct.ToString("0.0")%" title="Error">
                @if (errorPct > 5)
                {
                    <span>@Model.ProcessingMatrix.Error Error</span>
                }
            </div>
        </div>
        <div class="d-flex gap-3 mt-2 small text-muted">
            <span><i class="bi bi-circle-fill text-success me-1"></i>Processed: @Model.ProcessingMatrix.Processed</span>
            <span><i class="bi bi-circle-fill text-warning me-1"></i>Pending: @Model.ProcessingMatrix.Pending</span>
            <span><i class="bi bi-circle-fill text-danger me-1"></i>Error: @Model.ProcessingMatrix.Error</span>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3">
    <div class="col-md-6">
        <a asp-controller="Ingestion" asp-action="Customer" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 py-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-person-plus-fill text-primary fs-4"></i>
                </div>
                <div>
                    <div class="fw-semibold text-dark">Ingest Customer Master</div>
                    <div class="text-muted small">Submit new or updated customer data</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </div>
        </a>
    </div>
    <div class="col-md-6">
        <a asp-controller="Ingestion" asp-action="Item" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 py-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-plus-square-fill text-success fs-4"></i>
                </div>
                <div>
                    <div class="fw-semibold text-dark">Ingest Item Master</div>
                    <div class="text-muted small">Submit new or updated item data</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </div>
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // Ingestion Status Chart
        new Chart(document.getElementById('ingestionChart'), {
            type: 'doughnut',
            data: {
                labels: ['202 Success', '400 Failed'],
                datasets: [{
                    data: [@Model.IngestionMatrix.ApiSuccess, @Model.IngestionMatrix.ApiFailure],
                    backgroundColor: ['#198754','#dc3545'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                cutout: '65%',
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } }
            }
        });

        // Processing Status Chart
        new Chart(document.getElementById('processingChart'), {
            type: 'doughnut',
            data: {
                labels: ['Processed', 'Pending', 'Error'],
                datasets: [{
                    data: [@Model.ProcessingMatrix.Processed, @Model.ProcessingMatrix.Pending, @Model.ProcessingMatrix.Error],
                    backgroundColor: ['#198754','#ffc107','#dc3545'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                cutout: '65%',
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } }
            }
        });
    </script>
}
